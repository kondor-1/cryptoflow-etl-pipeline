# ── Secrets ────────────────────────────────────────────────────────────────
# NEVER commit the real .env — it contains your DB password
.env

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Data files ──────────────────────────────────────────────────────────────
# Raw API cache files — these are regenerated by the pipeline, not source code
data/

# ── Airflow ──────────────────────────────────────────────────────────────────
# Airflow generates a lot of local files — none of these belong in the repo
logs/
airflow.cfg
airflow.db
standalone_admin_password.txt
airflow/

# ── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store